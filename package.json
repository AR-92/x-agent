{
	"name": "@mariozechner/x-agent",
	"version": "1.0.0",
	"description": "Stateful AI agent with tool execution and event streaming - Browser ready",
	"type": "module",
	"main": "./dist/x-agent.umd.min.js",
	"module": "./dist/x-agent.min.js",
	"browser": "./dist/x-agent.min.js",
	"exports": {
		".": {
			"browser": "./dist/x-agent.min.js",
			"import": "./dist/x-agent.min.js",
			"require": "./dist/x-agent.umd.min.js"
		}
	},
	"files": [
		"dist",
		"src",
		"README.md"
	],
	"scripts": {
		"clean": "rm -rf dist",
		"build": "bun run build:cmd",
		"build:cmd": "vite build",
		"dev": "vite build --watch",
		"test": "bun test --coverage",
		"test:unit": "bun test test/agent.test.js test/agent-loop.test.js"
	},
	"dependencies": {
		"@mariozechner/pi-ai": "^0.55.0"
	},
	"keywords": [
		"ai",
		"agent",
		"llm",
		"tool-execution",
		"state-management",
		"browser",
		"esm"
	],
	"author": "Mario Zechner",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/badlogic/x-agent.git"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "^3.0.0",
		"vite": "^6.0.0",
		"vitest": "^3.2.4"
	}
}
